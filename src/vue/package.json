{
  "name": "factorio-tools",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run swagger-gen && vue-tsc && vite build && cd dist && shx cp index.html 404.html",
    "preview": "vite preview",
    "swagger-gen": "swagger-typescript-api generate --path ../WebApp/swagger.json --output src/lib --name FactorioToolsApi",
    "build-wasm": "dotnet publish ../BrowserWasm/BrowserWasm.csproj -c Release && shx rm -rf public/_framework && shx cp -r ../BrowserWasm/bin/Release/net8.0/browser-wasm/AppBundle/_framework public/"
  },
  "dependencies": {
    "bootstrap": "^5.2.3",
    "clipboardy": "^3.0.0",
    "pinia": "^2.0.32",
    "pinia-plugin-persistedstate": "^3.1.0",
    "vue": "^3.2.45",
    "vue-router": "^4.1.6"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "bootstrap": "^5.3.2",
    "clipboardy": "^3.0.0",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "sass": "^1.69.7",
    "shx": "^0.3.4",
    "swagger-typescript-api": "^13.12.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vue-router": "^4.2.5",
    "vue-tsc": "^3.3.5"
  },
  "overrides": {
    "esbuild": "0.27.2"
  }
}
